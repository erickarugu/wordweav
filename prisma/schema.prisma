// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?    @map("email_verified")
  image         String?
  password      String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  documents     Document[]
  usageStats    UsageStats[]

  @@map("users")
}

model Document {
  id             String             @id @default(cuid())
  userId         String             @map("user_id")
  title          String
  originalText   String             @map("original_text")
  processedText  String             @map("processed_text")
  wordCount      Int                @map("word_count")
  processingTime Int                @map("processing_time") // in milliseconds
  mechanisms     String // JSON string of processing mechanisms used
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  analytics      DocumentAnalytics?

  @@map("documents")
}

model DocumentAnalytics {
  id                String   @id @default(cuid())
  documentId        String   @unique @map("document_id")
  readabilityScore  Float?   @map("readability_score")
  sentimentScore    Float?   @map("sentiment_score")
  complexityScore   Float?   @map("complexity_score")
  improvementScore  Float?   @map("improvement_score")
  keywordDensity    Json?    @map("keyword_density") // JSON object
  grammarIssues     Int      @default(0) @map("grammar_issues")
  styleImprovements Int      @default(0) @map("style_improvements")
  wordsProcessed    Int      @default(0) @map("words_processed")
  timeSaved         Int      @default(0) @map("time_saved") // in minutes
  document          Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_analytics")
}

model UsageStats {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  month          Int // 1-12
  year           Int
  wordsProcessed Int      @default(0) @map("words_processed")
  documentsCount Int      @default(0) @map("documents_count")
  timeSaved      Int      @default(0) @map("time_saved") // in minutes
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("usage_stats")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}
