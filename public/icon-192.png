<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 192 192" width="192" height="192">
  <defs>
    <linearGradient id="pwa192-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f97316;stop-opacity:1" />
      <stop offset="25%" style="stop-color:#ea580c;stop-opacity:1" />
      <stop offset="75%" style="stop-color:#dc2626;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#b91c1c;stop-opacity:1" />
    </linearGradient>
    <filter id="pwa-shadow">
      <feDropShadow dx="0" dy="4" stdDeviation="8" flood-opacity="0.25"/>
    </filter>
  </defs>
  
  <!-- Background for PWA icon (maskable) -->
  <rect width="192" height="192" rx="48" fill="url(#pwa192-gradient)" filter="url(#pwa-shadow)"/>
  
  <!-- Large "W" with more detail -->
  <g fill="white" opacity="0.95" filter="url(#pwa-shadow)">
    <path d="M48 48 L58 144 L74 144 L92 88 L110 144 L126 144 L144 88 L162 144 L178 144 L158 48 L138 48 L120 104 L102 48 L90 48 L72 104 L54 48 Z"/>
    
    <!-- Inner highlight for depth -->
    <path d="M52 52 L60 140 L72 140 L88 92 L104 140 L120 140 L136 92 L152 140 L164 140 L148 52 L132 52 L120 100 L108 52 L96 52 L84 100 L72 52 Z" opacity="0.3"/>
  </g>
  
  <!-- Enhanced transformation elements -->
  <g opacity="0.8">
    <!-- AI elements (left side - geometric) -->
    <rect x="20" y="20" width="12" height="12" fill="white" opacity="0.7" rx="2"/>
    <rect x="20" y="38" width="10" height="10" fill="white" opacity="0.5" rx="2"/>
    <rect x="20" y="54" width="8" height="8" fill="white" opacity="0.4" rx="1"/>
    <rect x="20" y="68" width="6" height="6" fill="white" opacity="0.3" rx="1"/>
    
    <!-- Human elements (right side - organic) -->
    <circle cx="170" cy="26" r="6" fill="white" opacity="0.7"/>
    <circle cx="164" cy="40" r="5" fill="white" opacity="0.5"/>
    <circle cx="174" cy="54" r="4" fill="white" opacity="0.4"/>
    <circle cx="168" cy="68" r="3" fill="white" opacity="0.3"/>
  </g>
  
  <!-- Weave pattern details -->
  <g opacity="0.15" stroke="white" stroke-width="1" fill="none">
    <path d="M70 30 Q96 45 122 30 Q148 45 174 30"/>
    <path d="M70 162 Q96 147 122 162 Q148 147 174 162"/>
    <path d="M30 70 Q45 96 30 122 Q45 148 30 174"/>
    <path d="M162 70 Q147 96 162 122 Q147 148 162 174"/>
  </g>
</svg>